# === База данных ===
# PostgreSQL
DATABASE_URL=postgresql://user:password@localhost:5432/app_store_monitor

# Или SQLite (для разработки)
# DATABASE_URL=sqlite:///./app_store_monitor.db

# === Администратор ===
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme

# === Мониторинг ===
MONITOR_INTERVAL=30
MONITOR_JITTER=5

# === Rate Limiting ===
RATE_LIMIT=100

# === Email (раскомментировать для включения) ===
# EMAIL_ENABLED=true
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your_email@gmail.com
# SMTP_PASSWORD=your_app_password
# ALERT_EMAIL=admin@example.com

# === Telegram (раскомментировать для включения) ===
# TELEGRAM_ENABLED=false
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=

# === Google Sheets (раскомментировать для включения) ===
# GOOGLE_CREDENTIALS=
# SPREADSHEET_ID=
# SHEET_NAME=AppStoreMonitor
