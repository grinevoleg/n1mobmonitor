# ===================================
# Конфигурация App Store Monitor
# ===================================

# База данных (выберите ОДНО)
# Вариант 1: SQLite (для разработки)
DATABASE_URL=sqlite:///./app_store_monitor.db

# Вариант 2: PostgreSQL (для продакшена)
# DATABASE_URL=postgresql://user:password@localhost:5432/app_store_monitor

# Администратор (веб-интерфейс)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin

# Telegram Bot (для уведомлений и управления)
# Получить токен: https://t.me/BotFather
TELEGRAM_BOT_TOKEN=

# Включить бота (true для production, false для локальной разработки)
TELEGRAM_BOT_ENABLED=false

# Мониторинг
MONITOR_INTERVAL=30
MONITOR_JITTER=5

# Rate Limiting
RATE_LIMIT=100

# Email уведомления (опционально)
# EMAIL_ENABLED=true
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your_email@gmail.com
# SMTP_PASSWORD=your_app_password
# ALERT_EMAIL=admin@example.com

# Google Sheets (опционально)
# GOOGLE_CREDENTIALS=
# SPREADSHEET_ID=
# SHEET_NAME=AppStoreMonitor
