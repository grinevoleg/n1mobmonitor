# Database
DATABASE_URL=sqlite:///./app_store_monitor.db

# Google Sheets (опционально)
GOOGLE_CREDENTIALS={"type": "service_account", ...}
SPREADSHEET_ID=your_spreadsheet_id_here
SHEET_NAME=AppStoreMonitor

# Rate limiting (запросов в час на API ключ)
RATE_LIMIT=100

# Интервал мониторинга (минуты)
# Базовый интервал между проверками каждого приложения
MONITOR_INTERVAL=30

# Случайное отклонение от интервала (минуты)
# Для избежания паттернов "ботского" поведения
# Реальный интервал будет в диапазоне [MONITOR_INTERVAL - MONITOR_JITTER, MONITOR_INTERVAL + MONITOR_JITTER]
MONITOR_JITTER=5

# Пример: при MONITOR_INTERVAL=30 и MONITOR_JITTER=5
# Каждое приложение будет проверяться каждые 25-35 минут (случайно)

# Admin credentials (для доступа к настройкам)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme

# Email уведомления (опционально)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
ALERT_EMAIL=

# Telegram уведомления (опционально)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
